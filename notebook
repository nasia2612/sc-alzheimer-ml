        "import numpy as np\n",
        "import pandas as pd\n",
        "import gc\n",
        "from sklearn.model_selection import train_test_split\n",
        "import pyreadr\n",
        "\n",
        "#we import only the gene_names\n",
        "result = pyreadr.read_r(\"/content/drive/MyDrive/Colab Notebooks/sc_alzheimer/sc_alz_train_set.rds\")\n",
