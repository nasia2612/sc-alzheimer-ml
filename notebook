        "del result\n",
        "gc.collect()\n",
        "\n",
        "\n",
        "X_norm_df = pd.DataFrame(X_norm, columns=gene_names)\n",
        "del X_norm\n",
        "gc.collect()\n",
        "\n",
        "# Temporary split για MGECT\n",
        "X_train_temp, _, y_train_temp, _ = train_test_split(\n",
        "    X_norm_df, y, test_size=0.2, random_state=42, stratify=y\n",
