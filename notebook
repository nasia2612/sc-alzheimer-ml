        "#normalization of the data\n",
        "\n",
        "import numpy as np\n",
        "import gc\n",
        "\n",
        "# float32 - μισή μνήμη\n",
        "X_array = X.values.astype(np.float32)\n",
        "\n",
        "# Διέγραψε df και X ΑΜΕΣΩΣ\n",
        "del df, X\n",
        "gc.collect()\n",
        "\n",
        "# Normalization\n",
        "total_counts = X_array.sum(axis=1, keepdims=True)\n",
        "X_norm = X_array / total_counts * 1e6\n",
        "X_norm = np.log2(X_norm + 1)\n",
        "\n",
        "del X_array\n",
        "gc.collect()\n",
        "\n",
        "print(\"Max after norm:\", X_norm.max())\n",
        "print(\"Memory MB:\", X_norm.nbytes / 1e6)"
      ]
